# Node / React Native / Expo
node_modules/
.expo/
.expo-shared/
dist/
build/
web-build/

# Native projects (regenerate: npx expo prebuild)
android/
ios/

# Native build outputs
*.apk
*.aab
*.ipa
.gradle/
local.properties

# Python environments and caches (never commit)
.venv/
.venv*/
**/.venv*/
venv/
env/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# ML training outputs and raw data (not needed to run the app)
dataset/
ML/artifacts/

# Bundled models in App/assets/ are committed for clone-and-run (see README).
*.tflite
!App/assets/*.tflite
*.task
!App/assets/hand_landmarker.task

# Legacy TF.js export (not used by the dev client app)
*.bin
App/assets/asl_baseline_tfjs/
*.keras
*.h5
*.ckpt
*.pt
*.onnx

# App asset scratch / test exports
App/assets/**/_tmp_*/
App/assets/**/*_test/

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
!.env.example
kaggle.json

# Accidental shell redirect artifacts
=*
