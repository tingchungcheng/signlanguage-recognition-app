{
  "name": "signlanguage-recognition-app",
  "version": "1.0.0",
  "private": true,
  "description": "ASL sign recognition app (Expo dev client + native TFLite)",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "setup:app": "expo install expo-dev-client expo-speech expo-asset && npm install --legacy-peer-deps",
    "copy-ml-assets": "node scripts/copy-ml-assets.js",
    "prebuild": "expo prebuild",
    "android:clean-cache": "node scripts/android-clean-cache.js",
    "android:dev": "npm run copy-ml-assets && expo run:android",
    "ios:dev": "npm run copy-ml-assets && expo run:ios",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "babel-preset-expo": "~54.0.10",
    "expo": "^54.0.34",
    "expo-asset": "~12.0.13",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-vision-camera-v4-mediapipe": "^1.1.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.15.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-worklets-core": "^1.6.3",
    "vision-camera-resize-plugin": "^3.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-proposal-nullish-coalescing-operator": "^7.18.6",
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-arrow-functions": "^7.29.7",
    "@babel/plugin-transform-shorthand-properties": "^7.29.7",
    "@babel/plugin-transform-template-literals": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@types/react": "~19.1.10",
    "patch-package": "^8.0.1",
    "typescript": "^5.8.3"
  }
}
