{
  "name": "signlanguage-recognition-app",
  "version": "1.0.0",
  "private": true,
  "description": "RN sign language recognition app scaffold",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "export-tfjs": "python ML/export_tfjs.py",
    "setup:app": "expo install expo-asset expo-gl && npm install",
    "copy-ml-assets": "node scripts/copy-ml-assets.js",
    "prebuild": "expo prebuild",
    "android:dev": "npm run copy-ml-assets && expo run:android",
    "ios:dev": "npm run copy-ml-assets && expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@mediapipe/tasks-vision": "^0.10.22",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-react-native": "^1.0.0",
    "babel-preset-expo": "~54.0.10",
    "buffer": "^6.0.3",
    "expo": "^54.0.34",
    "expo-asset": "~12.0.13",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-gl": "~16.0.10",
    "expo-image-manipulator": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "jpeg-js": "^0.4.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fast-tflite": "^3.0.1",
    "react-native-fs": "^2.20.0",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets-core": "^1.6.3",
    "vision-camera-resize-plugin": "^3.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@types/react": "~19.1.10",
    "typescript": "^5.8.3"
  }
}
